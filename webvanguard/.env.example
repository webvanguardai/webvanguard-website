# Metrics data sources (optional)
# If not set, dashboard uses mock data.

# YouTube Analytics API v3
# Get these from Google Cloud Console (OAuth 2.0 credentials for Web Application)
NEXT_PUBLIC_YOUTUBE_API_KEY=your_api_key_here
# Optional: use OAuth refresh token for private data
YOUTUBE_REFRESH_TOKEN=your_refresh_token
YOUTUBE_CLIENT_ID=your_client_id
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_CHANNEL_ID=your_channel_id

# Leads data source: Google Sheets ID and range
NEXT_PUBLIC_LEADS_SHEET_ID=your_sheet_id
NEXT_PUBLIC_LEADS_SHEET_RANGE= Leads!A1:E100
